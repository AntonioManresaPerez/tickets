// Esquema de la base de datos del gestor de tickets.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

// Secciones independientes de la aplicación. Cada usuario accede a una o varias
// y todo (tareas, ideas, sprints) queda separado por sección.
enum Section {
  ESCALAS_MEDICAS
  PROGRAMACION
}

// Flujo de trabajo de un ticket.
enum TaskStatus {
  PENDING      // Pendiente
  IN_PROGRESS  // En progreso
  PAUSED       // Parada
  USER_REVIEW  // Revisión usuario
  ADMIN_REVIEW // Revisión admin
  DONE         // Producción / Finalizada
}

// Estado de un sprint.
enum SprintStatus {
  PLANNED   // Planificado
  ACTIVE    // Activo
  COMPLETED // Completado
}

enum Priority {
  LOW    // Baja
  MEDIUM // Media
  HIGH   // Alta
  URGENT // Urgente
}

// Vencimiento simplificado por "cubos" en lugar de fecha exacta.
enum DueBucket {
  NONE  // Sin fecha
  TODAY // Hoy
  WEEK  // Esta semana
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // hash bcrypt
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections Section[] @default([]) // secciones a las que tiene acceso

  createdTasks       Task[]         @relation("CreatedBy")
  assignedTasks      Task[]         @relation("AssignedTo")
  collaboratingTasks Task[]         @relation("Collaborators")
  comments           Comment[]
  notifications      Notification[]
  activities         Activity[]
  ideas              Idea[]
  ideaVotes          IdeaVote[]
  ideaComments       IdeaComment[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  prevStatus  TaskStatus? // estado antes de "Parada", para volver a él al continuar
  priority    Priority   @default(MEDIUM)
  section     Section
  hours       Float      @default(0)
  labels      String[]   @default([])
  dueBucket   DueBucket  @default(NONE)
  dueDate     DateTime?
  startedAt   DateTime? // cuándo pasó a "En progreso" por primera vez
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assigneeId String?
  assignee   User?   @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  collaborators User[] @relation("Collaborators")

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  comments       Comment[]
  activities     Activity[]
  checklistItems ChecklistItem[]

  @@index([status])
  @@index([priority])
  @@index([section])
  @@index([assigneeId])
  @@index([sprintId])
  @@index([createdAt])
  @@index([dueDate])
}

// Sprint / entrega que agrupa tareas dentro de una sección.
model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  section   Section
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime     @default(now())

  tasks Task[]

  @@index([section])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([taskId])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// Registro de auditoría ("Logs"): qué pasó, quién y cuándo.
model Activity {
  id        String   @id @default(cuid())
  action    String // CREATED, STATUS_CHANGED, ASSIGNED, COMMENTED, UPDATED...
  detail    String?
  createdAt DateTime @default(now())

  taskId Int?
  task   Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([createdAt])
}

// Catálogo de etiquetas (lo que se va a tocar: backend, frontend, etc.).
// El admin puede crear nuevas. En las tareas se guardan por nombre (Task.labels).
model Label {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

enum IdeaStatus {
  OPEN
  PLANNED
  DOING
  DONE
  REJECTED
}

model Idea {
  id        String     @id @default(cuid())
  title     String
  body      String?
  status    IdeaStatus @default(OPEN)
  category  String?
  section   Section
  links     String[]   @default([])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  votes    IdeaVote[]
  comments IdeaComment[]

  @@index([status])
  @@index([section])
  @@index([createdAt])
}

model IdeaVote {
  userId    String
  ideaId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@id([userId, ideaId])
}

model IdeaComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([ideaId])
}
